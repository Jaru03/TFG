{
  "name": "edutech",
  "version": "1.0.0",
  "description": "Plataforma e-learning con Node.js, Express, PostgreSQL, React y OAuth 2.0 (Google)",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "concurrently \"npm run server\" \"npm run client:dev\"",
    "server": "nodemon app.js",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "client:start": "npm --prefix client run preview"
  },
  "keywords": [
    "e-learning",
    "express",
    "nodejs",
    "oauth",
    "rbac"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "pg": "^8.11.1",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  }
}
